# === NHANES data (never commit) ===
# Ignore everything in these folders but keep the folders themselves (.gitkeep).
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
*.XPT
*.xpt
# Large CSVs — keep small reference CSVs by force-adding with `git add -f`
*.csv

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# === Notebooks ===
.ipynb_checkpoints/

# === Environments ===
venv/
.venv/
env/
ENV/
.env

# === Editors / OS ===
.vscode/
.idea/
.DS_Store
Thumbs.db
